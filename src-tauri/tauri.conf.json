{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zagorakys",
  "version": "1.3.0",
  "identifier": "com.zagorakys.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Zagorakys",
        "width": 680,
        "height": 820,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/sreckoskocilic/zagorakys/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM1MTAwNEQyMjgxODc2OEIKUldTTGRoZ28wZ1FReFRLeENuakh4N0pidS9WS04vdC9SZ1ArTHRncXBWbndjTkxETlFhQkV3aEkK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": "v1Compatible",
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/*"]
  }
}
